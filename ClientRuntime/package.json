{
  "name": "adh-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ADHTML client runtime — a tiny, dependency-free interpreter of the hydration wire format.",
  "scripts": {
    "test": "bun test ./test",
    "typecheck": "tsc --noEmit",
    "build": "bun run build.js",
    "build:components": "bun run build-components.js",
    "e2e": "playwright test",
    "bench": "bun profile/bench.js",
    "bench:compare": "bun profile/framework-compare.mjs",
    "bench:size": "bun profile/size-compare.mjs"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
